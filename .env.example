# 복사해서 .env 로 저장한 뒤 실제 키를 채우세요.
OPENAI_API_KEY=sk-여기에-키

# ── 메일 자동 발송(SMTP) ────────────────────────────────────────────
# 실험 결과·진행 이슈를 백그라운드 프로세스가 자체적으로 메일 발송할 때 사용.
# Gmail 사용 시: 2단계 인증을 켠 뒤 "앱 비밀번호" 16자리를 발급해 SMTP_PASSWORD 에 넣는다.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=발신Gmail주소@gmail.com
SMTP_PASSWORD=앱비밀번호16자리
# MAIL_FROM 미설정 시 SMTP_USER 사용. MAIL_TO 미설정 시 thomas@itengineers.net.
MAIL_FROM=발신Gmail주소@gmail.com
MAIL_TO=thomas@itengineers.net
